<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/amoled_black"
    android:fitsSystemWindows="true">

    <!-- Top Area -->
    <LinearLayout
        android:id="@+id/layoutTopInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvIncomingCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caller Name"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIncomingCallerNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="+91 98765 43210"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvSimIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="SIM 1"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvIncomingVolte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/rounded_card"
                android:backgroundTint="@color/keypad_btn_bg"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="VoLTE"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvIncomingVowifi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_card"
                android:backgroundTint="@color/keypad_btn_bg"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="VoWiFi"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Center Area -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivIncomingCallerPhoto"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="40dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_contacts"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopInfo"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="@color/white"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/tvSpamWarning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/rounded_card"
        android:backgroundTint="#33FF3B30"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Potential Spam"
        android:textColor="#FF3B30"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivIncomingCallerPhoto" />

    <!-- Secondary Actions (Message & Voicemail) -->
    <LinearLayout
        android:id="@+id/layoutIncomingSecondaryActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/barrierBottomButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/layoutQuickResponseHandle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="50dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_message"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Message"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnScreenCallVoicemail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="50dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/stat_notify_voicemail"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Voicemail"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrierBottomButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="layoutCallWaitingActions,swipeActionsContainer" />

    <!-- Call Waiting Actions Container (Samsung Style) -->
    <LinearLayout
        android:id="@+id/layoutCallWaitingActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="100dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/btnEndAndAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/red_circle"
                android:padding="20dp"
                android:src="@drawable/ic_phone"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="End &amp; answer"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnHoldAndAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/green_circle"
                android:padding="20dp"
                android:src="@drawable/ic_phone"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Hold &amp; answer"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnMergeAndAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/blue_circle"
                android:padding="20dp"
                android:src="@drawable/ic_add"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Merge"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnQuickMessageWaiting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/gray_circle"
                android:padding="20dp"
                android:src="@drawable/ic_message"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Message"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Swipe Actions Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/swipeActionsContainer"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Rings for Accept -->
        <View
            android:id="@+id/viewAcceptRing1"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:alpha="0"
            android:background="@drawable/ring_outline_green"
            app:layout_constraintBottom_toBottomOf="@id/layoutAccept"
            app:layout_constraintEnd_toEndOf="@id/layoutAccept"
            app:layout_constraintStart_toStartOf="@id/layoutAccept"
            app:layout_constraintTop_toTopOf="@id/layoutAccept" />

        <View
            android:id="@+id/viewAcceptRing2"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:alpha="0"
            android:background="@drawable/ring_outline_green"
            app:layout_constraintBottom_toBottomOf="@id/layoutAccept"
            app:layout_constraintEnd_toEndOf="@id/layoutAccept"
            app:layout_constraintStart_toStartOf="@id/layoutAccept"
            app:layout_constraintTop_toTopOf="@id/layoutAccept" />

        <FrameLayout
            android:id="@+id/layoutAccept"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginStart="40dp"
            android:background="@drawable/green_circle"
            android:elevation="8dp"
            android:foreground="@drawable/swipe_ripple"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_phone"
                app:tint="@color/white" />
        </FrameLayout>

        <!-- Rings for Reject -->
        <View
            android:id="@+id/viewRejectRing1"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:alpha="0"
            android:background="@drawable/ring_outline_red"
            app:layout_constraintBottom_toBottomOf="@id/layoutReject"
            app:layout_constraintEnd_toEndOf="@id/layoutReject"
            app:layout_constraintStart_toStartOf="@id/layoutReject"
            app:layout_constraintTop_toTopOf="@id/layoutReject" />

        <View
            android:id="@+id/viewRejectRing2"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:alpha="0"
            android:background="@drawable/ring_outline_red"
            app:layout_constraintBottom_toBottomOf="@id/layoutReject"
            app:layout_constraintEnd_toEndOf="@id/layoutReject"
            app:layout_constraintStart_toStartOf="@id/layoutReject"
            app:layout_constraintTop_toTopOf="@id/layoutReject" />

        <FrameLayout
            android:id="@+id/layoutReject"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginEnd="40dp"
            android:background="@drawable/red_circle"
            android:elevation="8dp"
            android:foreground="@drawable/swipe_ripple"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:rotation="45"
                android:src="@android:drawable/sym_action_call"
                app:tint="@color/white" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
