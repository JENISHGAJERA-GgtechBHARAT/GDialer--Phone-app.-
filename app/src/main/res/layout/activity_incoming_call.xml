<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/samsung_call_background"
    android:fitsSystemWindows="true">

    <!-- Top Area -->
    <LinearLayout
        android:id="@+id/layoutTopInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvIncomingCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Caller Name"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvIncomingCallerNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="+91 98765 43210"
            android:textColor="#B3FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvSimIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="SIM 1"
            android:textColor="#80FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Center Area -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivIncomingCallerPhoto"
        android:layout_width="175dp"
        android:layout_height="185dp"
        android:layout_marginTop="46dp"
        android:layout_marginBottom="118dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_contacts"
        app:layout_constraintBottom_toTopOf="@+id/swipeActionsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopInfo"
        app:shapeAppearanceOverlay="@style/CircleImage"
        app:strokeColor="@color/white"
        app:strokeWidth="2dp" />

    <TextView
        android:id="@+id/tvSpamWarning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/rounded_card"
        android:backgroundTint="#33FF3B30"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:text="Potential Spam"
        android:textColor="#FF3B30"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivIncomingCallerPhoto" />

    <!-- Quick Replies Area -->
    <HorizontalScrollView
        android:id="@+id/scrollQuickReplies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="24dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/barrierBottomButtons">
        <LinearLayout
            android:id="@+id/layoutQuickReplies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrierBottomButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="layoutCallWaitingActions,swipeActionsContainer" />

    <!-- Call Waiting Actions Container (Samsung Style) -->
    <LinearLayout
        android:id="@+id/layoutCallWaitingActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="100dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/btnEndAndAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:padding="20dp"
                android:background="@drawable/red_circle"
                android:src="@drawable/ic_phone_end"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="End &amp; answer"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnHoldAndAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:padding="20dp"
                android:background="@drawable/green_circle"
                android:src="@drawable/ic_phone"
                app:tint="@color/black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Hold &amp; answer"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnMergeAndAnswer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:padding="20dp"
                android:background="@drawable/blue_circle"
                android:src="@drawable/ic_add"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Merge"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnQuickMessageWaiting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:padding="20dp"
                android:background="@drawable/gray_circle"
                android:src="@drawable/ic_message"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Message"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Swipe Actions Area (Samsung Style) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/swipeActionsContainer"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginBottom="64dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Pickup (Left) -->
        <FrameLayout
            android:id="@+id/layoutAccept"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginStart="48dp"
            android:background="@drawable/green_circle"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_phone"
                app:tint="@color/black" />
        </FrameLayout>

        <!-- Decline (Right) -->
        <FrameLayout
            android:id="@+id/layoutReject"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginEnd="48dp"
            android:background="@drawable/red_circle"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@android:drawable/sym_action_call"
                app:tint="@color/white" />
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
