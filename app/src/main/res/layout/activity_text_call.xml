<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvTextCallHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Text Call"
        android:textColor="@color/accent_green"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/layoutInput"
        app:layout_constraintTop_toBottomOf="@id/tvTextCallHeader">

        <TextView
            android:id="@+id/tvChatHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/btnEndTextCall">

        <EditText
            android:id="@+id/etTextCallInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type a response..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/white"
            android:background="@drawable/rounded_card"
            android:backgroundTint="@color/card_bg"
            android:padding="12dp" />

        <ImageButton
            android:id="@+id/btnSendTextCall"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_message"
            android:background="@drawable/green_circle"
            app:tint="@color/black" />
    </LinearLayout>

    <Button
        android:id="@+id/btnEndTextCall"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="End Call"
        android:backgroundTint="@color/accent_red"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
