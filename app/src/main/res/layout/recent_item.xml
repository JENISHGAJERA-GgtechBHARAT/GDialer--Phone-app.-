<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/glass_card"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Static Details Row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <!-- Checkbox (Visible in selection mode) -->
        <CheckBox
            android:id="@+id/cbSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:clickable="false"
            android:focusable="false"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Call Type Icon (Incoming / Outgoing / Missed) -->
        <ImageView
            android:id="@+id/ivCallTypeIcon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_incoming"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/cbSelect"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Profile Picture / Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivRecentAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_contacts"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivCallTypeIcon"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="#1AFFFFFF"
            app:strokeWidth="1dp" />

        <!-- Name / Number & Timestamp -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivRecordingBadge"
            app:layout_constraintStart_toEndOf="@id/ivRecentAvatar"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvRecentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecentDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Today, 10:30 AM • 5m 2s"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Call Recording Badge (Show only if recorded) -->
        <ImageView
            android:id="@+id/ivRecordingBadge"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_record"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Expandable Actions Layout (Hidden by default) -->
    <LinearLayout
        android:id="@+id/layoutRecentExpandableActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:background="#0AFFFFFF"
        android:visibility="gone">

        <!-- Call Action -->
        <ImageButton
            android:id="@+id/btnExpandCall"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/green_circle"
            android:backgroundTint="#34C759"
            app:backgroundTint="#34C759"
            android:src="@drawable/ic_phone"
            android:padding="12dp"
            app:tint="@color/white" />

        <!-- Message Action -->
        <ImageButton
            android:id="@+id/btnExpandMessage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/blue_circle"
            android:backgroundTint="#3498DB"
            app:backgroundTint="#3498DB"
            android:src="@drawable/ic_message"
            android:padding="12dp"
            app:tint="@color/white" />

        <!-- Video Action -->
        <ImageButton
            android:id="@+id/btnExpandVideo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/green_circle"
            android:backgroundTint="#34C759"
            app:backgroundTint="#34C759"
            android:src="@drawable/ic_video_call"
            android:padding="12dp"
            app:tint="@color/white" />

        <!-- Details Info Action -->
        <ImageButton
            android:id="@+id/btnExpandInfo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/gray_circle"
            android:backgroundTint="#8E8E93"
            app:backgroundTint="#8E8E93"
            android:src="@drawable/ic_info"
            android:padding="12dp"
            app:tint="@color/white" />

    </LinearLayout>

</LinearLayout>
