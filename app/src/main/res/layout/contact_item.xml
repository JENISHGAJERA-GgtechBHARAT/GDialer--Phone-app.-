<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/glass_card"
    android:orientation="vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Static Details Row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="16dp">

        <!-- Checkbox (Visible in selection mode) -->
        <CheckBox
            android:id="@+id/cbSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:clickable="false"
            android:focusable="false"
            android:layout_marginEnd="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivContactAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_contacts"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/cbSelect"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/divider_color"
            app:strokeWidth="1dp" />

        <!-- Name & Number -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivContactAvatar"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvContactName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvContactNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="+91 98765 43210"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Expandable Actions Layout (Hidden by default) -->
    <LinearLayout
        android:id="@+id/layoutContactExpandableActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:background="#0AFFFFFF"
        android:visibility="gone">

        <!-- Call Action -->
        <ImageButton
            android:id="@+id/btnExpandCall"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/green_circle"
            android:backgroundTint="#34C759"
            app:backgroundTint="#34C759"
            android:src="@drawable/ic_phone"
            android:padding="12dp"
            app:tint="@color/white" />

        <!-- Message Action -->
        <ImageButton
            android:id="@+id/btnExpandMessage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/blue_circle"
            android:backgroundTint="#3498DB"
            app:backgroundTint="#3498DB"
            android:src="@drawable/ic_message"
            android:padding="12dp"
            app:tint="@color/white" />

        <!-- Video Action -->
        <ImageButton
            android:id="@+id/btnExpandVideo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/green_circle"
            android:backgroundTint="#34C759"
            app:backgroundTint="#34C759"
            android:src="@drawable/ic_video_call"
            android:padding="12dp"
            app:tint="@color/white" />

        <!-- Details Info Action -->
        <ImageButton
            android:id="@+id/btnExpandInfo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/gray_circle"
            android:backgroundTint="#8E8E93"
            app:backgroundTint="#8E8E93"
            android:src="@drawable/ic_info"
            android:padding="12dp"
            app:tint="@color/white" />

    </LinearLayout>

</LinearLayout>
