<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/glass_white_pressed">
    <item>
        <selector>
            <item android:state_activated="true">
                <shape android:shape="oval">
                    <solid android:color="@color/text_primary" />
                    <stroke android:width="2dp" android:color="@color/divider_color" />
                </shape>
            </item>
            <item>
                <shape android:shape="oval">
                    <solid android:color="@color/glass_white" />
                    <stroke android:width="1dp" android:color="@color/glass_border" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>